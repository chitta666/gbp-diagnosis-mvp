{
  "name": "gbp-cf-mvp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2025-01-01 --local",
    "deploy": "wrangler pages deploy public",
    "smoke": "node scripts/post-deploy-smoke.cjs",
    "events:summary": "node scripts/events-summary.mjs",
    "events:smoke": "node scripts/smoke-events-summary.mjs",
    "feedback:summary": "node scripts/feedback-summary.mjs",
    "feedback:smoke": "node scripts/smoke-feedback-summary.mjs",
    "health:prod": "node scripts/health-check.mjs --mode health --origin https://gbp-diagnosis-mvp.pages.dev",
    "health:smoke": "node scripts/health-check.mjs --mode smoke"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
